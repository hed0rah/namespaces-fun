#!/usr/bin/env bash
# =============================================================================
#  nsm - Namespace Manager
# =============================================================================
#  A practical tool for creating, listing, inspecting, entering, and cleaning
#  up Linux namespaces. Useful for development, debugging, and operations.
#
#  Usage: nsm <command> [options]
#
#  Commands:
#    list      List all namespaces on the system
#    inspect   Inspect namespaces of a process or container
#    create    Create a named namespace environment
#    enter     Enter an existing namespace
#    exec      Execute a command in a namespace
#    diff      Compare namespaces between two processes
#    tree      Show namespace hierarchy as a tree
#    destroy   Tear down a named namespace environment
#    ps        Show processes grouped by namespace
#    monitor   Watch namespace creation/destruction in real-time
#
#  Install: sudo cp nsm /usr/local/bin/nsm
# =============================================================================
set -euo pipefail

VERSION="1.0.0"
NSM_DIR="/run/nsm"
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# --- Helpers ---

die()  { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${CYAN}[nsm]${RESET} $*"; }
warn() { echo -e "${YELLOW}[nsm]${RESET} $*"; }
need_root() { [[ $EUID -eq 0 ]] || die "This command requires root. Use sudo."; }

usage() {
    cat <<'EOF'
nsm - Namespace Manager v%VERSION%

Usage: nsm <command> [options]

Commands:
  list                          List all namespaces on the system
  inspect <pid|name>            Inspect namespaces of a process
  create  <name> [--type TYPE]  Create a named namespace environment
  enter   <name> [--type TYPE]  Enter a named namespace
  exec    <name> -- <cmd...>    Execute a command in a namespace
  diff    <pid1> <pid2>         Compare namespaces between two processes
  tree                          Show namespace hierarchy
  destroy <name>                Remove a named namespace
  ps      [--ns-type TYPE]      Show processes grouped by namespace
  monitor                       Watch namespace events in real-time

Namespace types (for create/enter): net, uts, pid, mnt, ipc, user, cgroup, all
Default type: all

Examples:
  nsm list
  nsm create mybox --type net
  nsm enter mybox
  nsm exec mybox -- ip addr show
  nsm diff 1 $$
  nsm inspect $(pidof nginx)
  nsm destroy mybox

EOF
    exit 0
}

# === COMMANDS ================================================================

cmd_list() {
    # Use lsns if available, with better formatting
    if command -v lsns &>/dev/null; then
        echo -e "${BOLD}Namespaces on this system:${RESET}"
        echo ""
        lsns --output NS,TYPE,NPROCS,PID,USER,COMMAND "$@" 2>/dev/null
    else
        # Fallback: manually scan /proc
        echo -e "${BOLD}Namespaces on this system (manual scan):${RESET}"
        echo ""
        printf "%-12s %-8s %-8s %s\n" "NAMESPACE" "TYPE" "PID" "COMMAND"
        printf "%-12s %-8s %-8s %s\n" "---------" "----" "---" "-------"

        declare -A seen
        for pid_dir in /proc/[0-9]*/; do
            pid=$(basename "$pid_dir")
            for ns_file in "${pid_dir}ns"/*; do
                [[ -e "$ns_file" ]] || continue
                ns_type=$(basename "$ns_file")
                ns_id=$(readlink "$ns_file" 2>/dev/null) || continue
                if [[ -z "${seen[$ns_id]:-}" ]]; then
                    seen[$ns_id]=1
                    cmd=$(tr '\0' ' ' < "${pid_dir}cmdline" 2>/dev/null | head -c 40)
                    printf "%-12s %-8s %-8s %s\n" "$ns_id" "$ns_type" "$pid" "$cmd"
                fi
            done
        done 2>/dev/null | sort -k2
    fi

    # Also show nsm-managed namespaces
    if [[ -d "$NSM_DIR" ]] && [[ -n "$(ls -A "$NSM_DIR" 2>/dev/null)" ]]; then
        echo ""
        echo -e "${BOLD}nsm-managed namespaces:${RESET}"
        for conf in "$NSM_DIR"/*/config; do
            [[ -f "$conf" ]] || continue
            name=$(basename "$(dirname "$conf")")
            ns_types=$(grep '^TYPES=' "$conf" | cut -d= -f2)
            pid=$(cat "$(dirname "$conf")/pid" 2>/dev/null || echo "dead")
            printf "  %-20s types=%-15s holder_pid=%s\n" "$name" "$ns_types" "$pid"
        done
    fi
}

cmd_inspect() {
    local target="${1:?Usage: nsm inspect <pid|name>}"

    # If it's a name, look up the pid
    if [[ -f "$NSM_DIR/$target/pid" ]]; then
        target=$(cat "$NSM_DIR/$target/pid")
        info "Resolved to PID $target"
    fi

    # Validate PID
    [[ -d "/proc/$target" ]] || die "No such process: $target"

    local cmdline
    cmdline=$(tr '\0' ' ' < "/proc/$target/cmdline" 2>/dev/null | head -c 80)

    echo -e "${BOLD}Namespaces for PID $target${RESET} ($cmdline)"
    echo ""

    printf "  %-12s %-30s %s\n" "TYPE" "NAMESPACE" "SAME AS INIT?"
    printf "  %-12s %-30s %s\n" "----" "---------" "-------------"

    for ns in /proc/$target/ns/*; do
        ns_type=$(basename "$ns")
        target_ns=$(readlink "$ns" 2>/dev/null || echo "?")
        init_ns=$(readlink "/proc/1/ns/$ns_type" 2>/dev/null || echo "?")
        if [[ "$target_ns" == "$init_ns" ]]; then
            same="${DIM}yes (host)${RESET}"
        else
            same="${GREEN}NO (isolated)${RESET}"
        fi
        printf "  %-12s %-30s %b\n" "$ns_type" "$target_ns" "$same"
    done

    echo ""

    # Show cgroup info
    echo -e "  ${BOLD}Cgroup:${RESET}"
    cat "/proc/$target/cgroup" 2>/dev/null | sed 's/^/    /'

    # Show uid/gid maps if interesting
    local uid_map
    uid_map=$(cat "/proc/$target/uid_map" 2>/dev/null)
    if [[ -n "$uid_map" ]] && [[ "$uid_map" != *"4294967295"* ]]; then
        echo ""
        echo -e "  ${BOLD}UID map:${RESET}"
        echo "$uid_map" | sed 's/^/    /'
    fi
}

cmd_create() {
    need_root
    local name="${1:?Usage: nsm create <name> [--type TYPE]}"
    shift
    local ns_types="all"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type|-t) ns_types="$2"; shift 2 ;;
            *) die "Unknown option: $1" ;;
        esac
    done

    mkdir -p "$NSM_DIR/$name"
    [[ ! -f "$NSM_DIR/$name/pid" ]] || {
        local old_pid
        old_pid=$(cat "$NSM_DIR/$name/pid")
        if kill -0 "$old_pid" 2>/dev/null; then
            die "Namespace '$name' already exists (PID $old_pid). Destroy it first."
        fi
        warn "Stale namespace '$name' (PID $old_pid dead). Recreating."
    }

    # Build unshare flags
    local flags=""
    case "$ns_types" in
        all) flags="--pid --uts --mount --ipc --net --fork --mount-proc" ;;
        net) flags="--net" ;;
        uts) flags="--uts" ;;
        pid) flags="--pid --fork --mount-proc" ;;
        mnt) flags="--mount" ;;
        ipc) flags="--ipc" ;;
        user) flags="--user --map-root-user" ;;
        cgroup) flags="--cgroup" ;;
        *) die "Unknown namespace type: $ns_types (use: net, uts, pid, mnt, ipc, user, cgroup, all)" ;;
    esac

    # Create bind-mountable reference points for persistent namespaces
    # We use a long-lived sleep process as the namespace holder
    info "Creating namespace '$name' (types: $ns_types)..."

    # For net namespaces, use ip netns which integrates with iproute2
    if [[ "$ns_types" == "net" ]]; then
        ip netns add "$name"
        echo "ip-netns" > "$NSM_DIR/$name/method"
    else
        # General case: use unshare with a holder process
        unshare $flags -- sleep infinity &
        local holder_pid=$!
        sleep 0.3

        if ! kill -0 "$holder_pid" 2>/dev/null; then
            die "Failed to create namespace holder process"
        fi

        echo "$holder_pid" > "$NSM_DIR/$name/pid"
    fi

    # Save config
    cat > "$NSM_DIR/$name/config" <<CONF
NAME=$name
TYPES=$ns_types
CREATED=$(date -Iseconds)
CREATED_BY=$(whoami)
CONF

    info "Namespace '$name' created successfully."

    if [[ "$ns_types" == "net" ]]; then
        info "Enter with: nsm enter $name"
        info "Or:         ip netns exec $name bash"
    else
        info "Enter with: nsm enter $name"
        info "Holder PID: $(cat "$NSM_DIR/$name/pid")"
    fi
}

cmd_enter() {
    need_root
    local name="${1:?Usage: nsm enter <name>}"
    shift

    if [[ -f "$NSM_DIR/$name/method" ]] && [[ "$(cat "$NSM_DIR/$name/method")" == "ip-netns" ]]; then
        info "Entering network namespace '$name'..."
        ip netns exec "$name" bash
        return
    fi

    local pid_file="$NSM_DIR/$name/pid"
    [[ -f "$pid_file" ]] || die "No namespace '$name' found. Create it first."

    local pid
    pid=$(cat "$pid_file")
    kill -0 "$pid" 2>/dev/null || die "Namespace holder (PID $pid) is dead. Destroy and recreate."

    local ns_types
    ns_types=$(grep '^TYPES=' "$NSM_DIR/$name/config" | cut -d= -f2)

    # Build nsenter flags
    local flags="--target $pid"
    case "$ns_types" in
        all) flags+=" --pid --uts --mount --ipc --net" ;;
        net) flags+=" --net" ;;
        uts) flags+=" --uts" ;;
        pid) flags+=" --pid --mount" ;;
        mnt) flags+=" --mount" ;;
        ipc) flags+=" --ipc" ;;
        user) flags+=" --user" ;;
        cgroup) flags+=" --cgroup" ;;
    esac

    info "Entering namespace '$name' (PID $pid, types: $ns_types)..."
    nsenter $flags -- "${@:-bash}"
}

cmd_exec() {
    need_root
    local name="${1:?Usage: nsm exec <name> -- <command>}"
    shift

    # Skip past --
    while [[ $# -gt 0 ]] && [[ "$1" != "--" ]]; do shift; done
    [[ $# -gt 0 ]] && shift  # skip the --

    [[ $# -gt 0 ]] || die "No command specified. Usage: nsm exec <name> -- <command>"

    # Reuse enter logic
    cmd_enter "$name" "$@"
}

cmd_diff() {
    local pid1="${1:?Usage: nsm diff <pid1> <pid2>}"
    local pid2="${2:?Usage: nsm diff <pid1> <pid2>}"

    [[ -d "/proc/$pid1" ]] || die "No such process: $pid1"
    [[ -d "/proc/$pid2" ]] || die "No such process: $pid2"

    local cmd1 cmd2
    cmd1=$(tr '\0' ' ' < "/proc/$pid1/cmdline" 2>/dev/null | head -c 40)
    cmd2=$(tr '\0' ' ' < "/proc/$pid2/cmdline" 2>/dev/null | head -c 40)

    echo -e "${BOLD}Namespace comparison: PID $pid1 vs PID $pid2${RESET}"
    echo -e "  PID $pid1: $cmd1"
    echo -e "  PID $pid2: $cmd2"
    echo ""

    printf "  %-12s %-8s %-30s %s\n" "TYPE" "SHARED?" "PID $pid1" "PID $pid2"
    printf "  %-12s %-8s %-30s %s\n" "----" "-------" "--------" "--------"

    local shared=0 different=0
    for ns in /proc/$pid1/ns/*; do
        ns_type=$(basename "$ns")
        ns1=$(readlink "$ns" 2>/dev/null || echo "?")
        ns2=$(readlink "/proc/$pid2/ns/$ns_type" 2>/dev/null || echo "?")
        if [[ "$ns1" == "$ns2" ]]; then
            status="${GREEN}same${RESET}"
            shared=$((shared + 1))
        else
            status="${RED}DIFF${RESET}"
            different=$((different + 1))
        fi
        printf "  %-12s %b   %-30s %s\n" "$ns_type" "$status" "$ns1" "$ns2"
    done

    echo ""
    echo -e "  ${GREEN}Shared: $shared${RESET}  ${RED}Different: $different${RESET}"
}

cmd_tree() {
    echo -e "${BOLD}Namespace tree (PID namespaces):${RESET}"
    echo ""

    if command -v lsns &>/dev/null; then
        # Build a tree from lsns output
        lsns -t pid --output NS,NPROCS,PID,COMMAND 2>/dev/null | head -30

        echo ""
        echo -e "${BOLD}All namespace types:${RESET}"
        echo ""
        for ns_type in cgroup ipc mnt net pid user uts; do
            count=$(lsns -t "$ns_type" 2>/dev/null | tail -n +2 | wc -l)
            bar=$(printf '%*s' "$count" '' | tr ' ' '█')
            printf "  %-8s %3d %s\n" "$ns_type" "$count" "$bar"
        done
    else
        # Manual approach
        declare -A ns_counts
        for pid_dir in /proc/[0-9]*/; do
            for ns_file in "${pid_dir}ns"/*; do
                [[ -e "$ns_file" ]] || continue
                ns_type=$(basename "$ns_file")
                ns_id=$(readlink "$ns_file" 2>/dev/null) || continue
                ns_counts["${ns_type}:${ns_id}"]=1
            done
        done 2>/dev/null

        for ns_type in cgroup ipc mnt net pid user uts; do
            count=0
            for key in "${!ns_counts[@]}"; do
                [[ "$key" == "${ns_type}:"* ]] && count=$((count + 1))
            done
            bar=$(printf '%*s' "$count" '' | tr ' ' '█')
            printf "  %-8s %3d %s\n" "$ns_type" "$count" "$bar"
        done
    fi
}

cmd_destroy() {
    need_root
    local name="${1:?Usage: nsm destroy <name>}"

    if [[ -f "$NSM_DIR/$name/method" ]] && [[ "$(cat "$NSM_DIR/$name/method")" == "ip-netns" ]]; then
        info "Removing network namespace '$name'..."
        ip netns del "$name" 2>/dev/null || true
        rm -rf "$NSM_DIR/$name"
        info "Destroyed."
        return
    fi

    local pid_file="$NSM_DIR/$name/pid"
    [[ -d "$NSM_DIR/$name" ]] || die "No namespace '$name' found."

    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            info "Killing holder process (PID $pid)..."
            kill "$pid" 2>/dev/null
            wait "$pid" 2>/dev/null || true
        fi
    fi

    rm -rf "$NSM_DIR/$name"
    info "Namespace '$name' destroyed."
}

cmd_ps() {
    local filter_type="${1:-pid}"
    [[ "$1" == "--ns-type" ]] && filter_type="${2:-pid}"

    echo -e "${BOLD}Processes grouped by ${filter_type} namespace:${RESET}"
    echo ""

    declare -A ns_pids
    for pid_dir in /proc/[0-9]*/; do
        pid=$(basename "$pid_dir")
        ns=$(readlink "${pid_dir}ns/$filter_type" 2>/dev/null) || continue
        ns_pids["$ns"]+="$pid "
    done 2>/dev/null

    for ns in "${!ns_pids[@]}"; do
        local pids=(${ns_pids[$ns]})
        echo -e "  ${CYAN}$ns${RESET} (${#pids[@]} processes)"

        local shown=0
        for pid in "${pids[@]}"; do
            cmd=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null | head -c 60)
            [[ -n "$cmd" ]] || cmd="[kernel]"
            printf "    %-8s %s\n" "$pid" "$cmd"
            shown=$((shown + 1))
            if [[ $shown -ge 5 ]] && [[ ${#pids[@]} -gt 6 ]]; then
                echo "    ... and $((${#pids[@]} - shown)) more"
                break
            fi
        done
        echo ""
    done
}

cmd_monitor() {
    need_root
    info "Monitoring namespace events (Ctrl+C to stop)..."
    info "Watching /proc for namespace changes..."
    echo ""

    # Snapshot current namespaces
    declare -A baseline
    for pid_dir in /proc/[0-9]*/; do
        pid=$(basename "$pid_dir")
        for ns_file in "${pid_dir}ns"/*; do
            [[ -e "$ns_file" ]] || continue
            ns_type=$(basename "$ns_file")
            ns_id=$(readlink "$ns_file" 2>/dev/null) || continue
            baseline["${ns_type}:${ns_id}"]=1
        done
    done 2>/dev/null

    while true; do
        sleep 1
        declare -A current
        for pid_dir in /proc/[0-9]*/; do
            pid=$(basename "$pid_dir")
            for ns_file in "${pid_dir}ns"/*; do
                [[ -e "$ns_file" ]] || continue
                ns_type=$(basename "$ns_file")
                ns_id=$(readlink "$ns_file" 2>/dev/null) || continue
                current["${ns_type}:${ns_id}"]=1

                if [[ -z "${baseline["${ns_type}:${ns_id}"]:-}" ]]; then
                    cmd=$(tr '\0' ' ' < "${pid_dir}cmdline" 2>/dev/null | head -c 50)
                    echo -e "$(date +%H:%M:%S) ${GREEN}+ NEW${RESET} ${ns_type} ${ns_id} pid=$pid cmd=$cmd"
                fi
            done
        done 2>/dev/null

        for key in "${!baseline[@]}"; do
            if [[ -z "${current[$key]:-}" ]]; then
                echo -e "$(date +%H:%M:%S) ${RED}- GONE${RESET} ${key}"
            fi
        done

        # Update baseline
        unset baseline
        declare -A baseline
        for key in "${!current[@]}"; do
            baseline["$key"]=1
        done
        unset current
    done
}

# === MAIN ====================================================================

[[ $# -gt 0 ]] || usage

cmd="$1"; shift
case "$cmd" in
    list|ls)        cmd_list "$@" ;;
    inspect|info)   cmd_inspect "$@" ;;
    create|new)     cmd_create "$@" ;;
    enter|shell)    cmd_enter "$@" ;;
    exec|run)       cmd_exec "$@" ;;
    diff|compare)   cmd_diff "$@" ;;
    tree)           cmd_tree "$@" ;;
    destroy|rm|del) cmd_destroy "$@" ;;
    ps|procs)       cmd_ps "$@" ;;
    monitor|watch)  cmd_monitor "$@" ;;
    -h|--help|help) usage ;;
    -v|--version)   echo "nsm $VERSION" ;;
    *)              die "Unknown command: $cmd (try: nsm --help)" ;;
esac
